# Environment Variables Example

SERVICE_NAME=eebook-users
APP_ENV=prod
DEBUG=false

FASTAPI_SECRET=CHANGE_ME_WITH_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=RS256
JWT_SECRET=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

POSTGRES_USER=users_service
POSTGRES_PASSWORD=CHANGE_ME_WITH_STRONG_PASSWORD
POSTGRES_DB=users_main
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
SUBSCRIPTIONS_SERVICE_URL=http://subscriptions:8000

CORS_ORIGINS=["http://localhost:3000"]

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=15
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

API_HOST=0.0.0.0
API_PORT=8000
